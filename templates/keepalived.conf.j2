# roles/keepalived/templates/keepalived.conf.j2

! Configuration File for Keepalived

global_defs {
  router_id {{ keepalived_router_id }}
}

{% if keepalived_track_process | bool %}
vrrp_track_process track_{{ keepalived_track_process_name | lower | replace('-', '_') }} {
  process {{ keepalived_track_process_name }}
  weight 50
}

{% endif %}
{% for instance in keepalived_instances_effective %}
vrrp_instance {{ instance.name }} {
  state {{ instance.state }}
  interface {{ instance.interface }}
  virtual_router_id {{ instance.virtual_router_id }}
  priority {{ instance.priority }}
  advert_int {{ instance.advert_interval }}

  unicast_src_ip {{ instance.unicast_src_ip }}
  unicast_peer {
    {{ instance.unicast_peers | sort | join('\n    ') }}
  }

  authentication {
    auth_type PASS
    auth_pass {{ instance.authentication_password }}
  }

  virtual_ipaddress {
    {{ instance.virtual_ipaddress | sort | join('\n    ') }}
  }
{% if keepalived_track_process | bool %}

  track_process {
    track_{{ keepalived_track_process_name | lower | replace('-', '_') }}
  }
{% endif %}
}
{% endfor %}
